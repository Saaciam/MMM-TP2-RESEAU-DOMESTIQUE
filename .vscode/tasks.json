{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build & Install",
      "type": "shell",
      "command": "./gradlew",
      "args": ["installDebug"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Launch App on Emulator",
      "type": "shell",
      "isBackground": false,
      "command": "adb",
      "args": [
        "shell",
        "am",
        "start",
        "-W",
        "-n",
        "com.example.mmm_tp2/com.example.mmm_tp2.MainActivity"
      ],
      "dependsOn": ["Build & Install"],
      "problemMatcher": []
    }
  ]
}
